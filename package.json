{
  "name": "stripe-preauth",
  "version": "1.0.0",
  "type": "module",
  "main": "backend/index.mjs",
  "scripts": {
    "start": "node backend/index.mjs",
    "dev": "bash scripts/dev.sh",
    "stripe:listen": "stripe listen --forward-to localhost:4242/webhook",
    "stripe:secret": "stripe listen --print-secret",
    "emulators:auth": "XDG_CONFIG_HOME=.firebase-config NO_UPDATE_NOTIFIER=1 firebase emulators:start --only auth --project servi-bec91",
    "start:auth-emulator": "FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 FIREBASE_PROJECT_ID=servi-bec91 DISABLE_RATE_LIMITS=1 node backend/index.mjs",
    "test:e2e": "node tests/preflight.mjs && playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.7.0",
    "lowdb": "^7.0.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.7",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "stripe": "^18.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.32.0",
    "firebase-tools": "^15.16.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2"
  }
}
