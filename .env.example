# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_TOKEN=a-long-random-secret-string

# ── Frontend ───────────────────────────────────────────────────────────────────
# URL of the Cloudflare Pages deployment (no trailing slash)
FRONTEND_BASE_URL=https://servi-preauth.pages.dev

# ── Google Apps Script ─────────────────────────────────────────────────────────
# The exec URL of the deployed Apps Script web app
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (in addition to FRONTEND_BASE_URL)
# CORS_ALLOWLIST=https://example.com,https://other.com

# ── Node ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
